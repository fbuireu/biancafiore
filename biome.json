{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	"files": {
		"includes": ["**", "!**/src/data/**/*", "!**/public/**/*"]
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"vcs": {
		"enabled": true,
		"useIgnoreFile": true,
		"clientKind": "git",
		"defaultBranch": "main"
	},
	"formatter": {
		"lineWidth": 120
	},
	"css": {
		"formatter": {
			"enabled": true
		}
	},
	"linter": {
		"includes": ["**", "!**/*.d.ts*"],
		"rules": {
			"preset": "recommended",
			"correctness": {
				"noUnknownProperty": "info"
			},
			"suspicious": {
				"noConsole": "error"
			}
		}
	},
	"overrides": [
		{
			"includes": ["**/*.astro"],
			"linter": {
				"rules": {
					"correctness": {
						"noUnusedImports": "off",
						"noUnusedVariables": "off"
					}
				}
			}
		}
	]
}
