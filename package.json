{
  "name": "biancafiore",
  "description": "A portfolio for the best content writer ever",
  "keywords": [
    "astro",
    "typescript",
    "css",
    "cloudflare",
    "NGO",
    "blog",
    "portfolio",
    "marketing",
    "content writing",
    "seo",
    "turso",
    "resend"
  ],
  "author": "Ferran Buireu <fbuireu@gmail.com>",
  "version": "2.0.2",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": "v24.14.1"
  },
  "scripts": {
    "prepare": "husky",
    "start": "astro dev --open --remote",
    "build": "pnpm check && astro build --remote",
    "preview": "astro preview",
    "sync": "astro sync",
    "check": "astro check",
    "test:all": "pnpm test:ut && pnpm test:e2e",
    "test:ut": "vitest --passWithNoTests --logHeapUsage",
    "test:ut:changed": "pnpm test:ut --bail --findRelatedTests",
    "test:e2e": "playwright test --pass-with-no-tests",
    "test:e2e:ui": "pnpm test:e2e --ui",
    "test:e2e:changed": "pnpm test:e2e --only-changed",
    "format": "biome check --write --no-errors-on-unmatched",
    "format:changed": "pnpm format --changed",
    "format:all": "pnpm format .",
    "lint": "biome lint --no-errors-on-unmatched",
    "lint:all": "pnpm lint .",
    "lint:all:fix": "pnpm lint:all --fix",
    "lint:changed": "pnpm lint --write --changed",
    "lint:ts:typecheck": "tsc --project . --noEmit"
  },
  "dependencies": {
    "@astrojs/cloudflare": "13.2.2",
    "@astrojs/compiler-rs": "0.1.10",
    "@astrojs/db": "0.21.0",
    "@astrojs/mdx": "5.0.4",
    "@astrojs/partytown": "2.1.7",
    "@astrojs/react": "5.0.4",
    "@astrojs/rss": "4.0.18",
    "@astrojs/sitemap": "3.7.2",
    "@contentful/rich-text-html-renderer": "17.2.2",
    "@contentful/rich-text-types": "17.2.7",
    "@hookform/resolvers": "5.2.2",
    "algoliasearch": "5.51.0",
    "astro": "6.1.10",
    "clsx": "2.1.1",
    "contentful": "11.12.1",
    "gsap": "3.15.0",
    "markdown-it": "14.1.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-globe.gl": "2.37.1",
    "react-google-recaptcha-v3": "1.11.0",
    "react-hook-form": "7.73.1",
    "resend": "6.12.2",
    "three": "0.184.0",
    "vanilla-cookieconsent": "3.1.0"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/ts-plugin": "1.10.7",
    "@biomejs/biome": "2.4.13",
    "@commitlint/cli": "20.5.2",
    "@commitlint/config-conventional": "20.5.0",
    "@commitlint/format": "20.5.0",
    "@playwright/test": "1.59.1",
    "@testing-library/react": "16.3.2",
    "@types/markdown-it": "14.1.2",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.184.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5",
    "wrangler": "4.84.0"
  }
}
