{
  "name": "biancafiore",
  "description": "A portfolio for the best content writer ever",
  "keywords": [
    "astro",
    "typescript",
    "css",
    "cloudflare",
    "NGO",
    "blog",
    "portfolio",
    "marketing",
    "content writing",
    "seo",
    "turso",
    "resend"
  ],
  "author": "Ferran Buireu <fbuireu@gmail.com>",
  "version": "1.14.0",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": "26.4.0"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "astro dev --open",
    "build": "astro build",
    "deploy": "wrangler deploy --env production",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "wrangler:dev": "pnpm build && wrangler dev --remote",
    "preview": "astro preview",
    "sync": "astro sync",
    "check": "astro check",
    "test:all": "pnpm test:ut && pnpm test:e2e",
    "test:ut": "vitest --passWithNoTests --logHeapUsage",
    "test:ut:changed": "pnpm test:ut --bail --findRelatedTests",
    "test:e2e": "playwright test --pass-with-no-tests",
    "test:e2e:ui": "pnpm test:e2e --ui",
    "test:e2e:changed": "pnpm test:e2e --only-changed",
    "format": "biome check --write --no-errors-on-unmatched",
    "format:changed": "pnpm format --changed",
    "format:all": "pnpm format .",
    "lint": "biome lint --no-errors-on-unmatched",
    "lint:all": "pnpm lint .",
    "lint:all:fix": "pnpm lint:all --fix",
    "lint:changed": "pnpm lint --write --changed",
    "lint:ts:typecheck": "tsc --project . --noEmit"
  },
  "dependencies": {
    "@astrojs/cloudflare": "14.0.1",
    "@astrojs/compiler-rs": "0.2.3",
    "@astrojs/react": "6.0.0",
    "@astrojs/rss": "4.0.18",
    "@astrojs/sitemap": "3.7.3",
    "@contentful/rich-text-html-renderer": "17.2.2",
    "@contentful/rich-text-types": "17.2.7",
    "@hookform/resolvers": "5.4.0",
    "@libsql/client": "0.17.4",
    "@tgwf/co2": "0.18.0",
    "astro": "7.0.3",
    "clsx": "2.1.1",
    "contentful": "11.12.6",
    "drizzle-orm": "0.45.2",
    "effect": "3.21.4",
    "gsap": "3.15.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-globe.gl": "2.38.0",
    "react-google-recaptcha-v3": "1.11.0",
    "react-hook-form": "7.80.0",
    "resend": "6.16.0",
    "three": "0.185.0",
    "vanilla-cookieconsent": "3.1.0"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/ts-plugin": "1.10.9",
    "@biomejs/biome": "2.5.1",
    "@commitlint/cli": "21.1.0",
    "@commitlint/config-conventional": "21.1.0",
    "@commitlint/format": "21.1.0",
    "@playwright/test": "1.61.1",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/npm": "13.1.5",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.185.0",
    "@vitest/coverage-v8": "4.1.9",
    "drizzle-kit": "0.31.10",
    "husky": "9.1.7",
    "lightningcss": "1.32.0",
    "lint-staged": "17.0.8",
    "semantic-release": "25.0.5",
    "typescript": "6.0.3",
    "vitest": "4.1.9",
    "wrangler": "4.105.0"
  }
}
