{
  "name": "biancafiore",
  "description": "A portfolio for the best content writer ever",
  "keywords": [
    "astro",
    "typescript",
    "css",
    "cloudflare",
    "NGO",
    "blog",
    "portfolio",
    "marketing",
    "content writing",
    "seo",
    "turso",
    "resend"
  ],
  "author": "Ferran Buireu <fbuireu@gmail.com>",
  "version": "1.4.9",
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": "v26.0.0"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "astro dev --open --remote",
    "build": "astro build --remote",
    "deploy": "wrangler deploy --env production",
    "preview": "astro preview",
    "sync": "astro sync",
    "check": "astro check",
    "test:all": "pnpm test:ut && pnpm test:e2e",
    "test:ut": "vitest --passWithNoTests --logHeapUsage",
    "test:ut:changed": "pnpm test:ut --bail --findRelatedTests",
    "test:e2e": "playwright test --pass-with-no-tests",
    "test:e2e:ui": "pnpm test:e2e --ui",
    "test:e2e:changed": "pnpm test:e2e --only-changed",
    "format": "biome check --write --no-errors-on-unmatched",
    "format:changed": "pnpm format --changed",
    "format:all": "pnpm format .",
    "lint": "biome lint --no-errors-on-unmatched",
    "lint:all": "pnpm lint .",
    "lint:all:fix": "pnpm lint:all --fix",
    "lint:changed": "pnpm lint --write --changed",
    "lint:ts:typecheck": "tsc --project . --noEmit"
  },
  "dependencies": {
    "@astrojs/cloudflare": "13.5.5",
    "@astrojs/compiler-rs": "0.2.1",
    "@astrojs/db": "https://pkg.pr.new/@astrojs/db@3ade645",
    "@astrojs/mdx": "5.0.6",
    "@astrojs/partytown": "2.1.7",
    "@astrojs/react": "5.0.5",
    "@astrojs/rss": "4.0.18",
    "@astrojs/sitemap": "3.7.3",
    "@contentful/rich-text-html-renderer": "17.2.2",
    "@contentful/rich-text-types": "17.2.7",
    "@hookform/resolvers": "5.4.0",
    "@tgwf/co2": "^0.18.0",
    "astro": "6.3.8",
    "clsx": "2.1.1",
    "contentful": "11.12.2",
    "gsap": "3.15.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-globe.gl": "2.38.0",
    "react-google-recaptcha-v3": "1.11.0",
    "react-hook-form": "7.76.1",
    "resend": "6.12.4",
    "three": "0.184.0",
    "vanilla-cookieconsent": "3.1.0"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/ts-plugin": "1.10.9",
    "@biomejs/biome": "2.4.15",
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@commitlint/format": "21.0.1",
    "@playwright/test": "1.60.0",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/npm": "13.1.5",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.184.1",
    "husky": "9.1.7",
    "lint-staged": "17.0.5",
    "semantic-release": "25.0.3",
    "typescript": "6.0.3",
    "vitest": "4.1.7",
    "wrangler": "4.95.0"
  }
}
