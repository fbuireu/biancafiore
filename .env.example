SITE_URL=https://biancafiore.me
BIANCA_EMAIL=abcde@abcde.xyz
TWITTER_HANDLE=abcde@abcde.xyz
GOOGLE_ANALYTICS_ID=YOUR_PUBLIC_GOOGLE_ANALYTICS_ID
GOOGLE_TAG_MANAGER_ID=YOUR_PUBLIC_GOOGLE_TAG_MANAGER_ID
GOOGLE_RECAPTCHA_SITE_KEY=YOUR_PUBLIC_GOOGLE_RECAPTCHA_SITE_KEY
GOOGLE_RECAPTCHA_SECRET_KEY=YOUR_GOOGLE_RECAPTCHA_SECRET_KEY
RESEND_API_KEY=YOUR_RESEND_API_KEY
# EmDash database (Turso/libSQL) — used at build/runtime in production.
EMDASH_TURSO_URL=libsql://your-emdash-db.turso.io
EMDASH_TURSO_AUTH_TOKEN=YOUR_TURSO_AUTH_TOKEN
# EmDash media storage (Cloudflare R2 over its S3-compatible API).
EMDASH_R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
EMDASH_R2_BUCKET=biancafiore-media
EMDASH_R2_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY_ID
EMDASH_R2_SECRET_ACCESS_KEY=YOUR_R2_SECRET_ACCESS_KEY
EMDASH_R2_PUBLIC_URL=https://media.biancafiore.me
# EmDash instance URL + API token — only for the CLI (`pnpm cms:types`) and the
# one-off migration script (`pnpm cms:migrate`).
EMDASH_API_URL=https://biancafiore.me
EMDASH_API_TOKEN=YOUR_EMDASH_API_TOKEN
# Source Contentful credentials, only used by the migration script.
MIGRATION_CONTENTFUL_SPACE_ID=YOUR_CONTENTFUL_SPACE_ID
MIGRATION_CONTENTFUL_DELIVERY_TOKEN=YOUR_CONTENTFUL_DELIVERY_TOKEN
ASTRO_DB_REMOTE_URL=YOUR_ASTRO_DB_REMOTE_URL
ASTRO_DB_APP_TOKEN=YOUR_ASTRO_DB_APP_TOKEN
HIDE_CHROME=false
