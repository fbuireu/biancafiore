const authors = await getCollection("authors");
const author = authors.find((a) => a.data.name === CONTACT_DETAILS.NAME) as CollectionEntry<"authors">;

const metadata: Partial<SeoMetadata> = {
	description: author.data.description,
	image: `https:${author.data.profileImage.url}`,
};
---
<BaseLayout {...metadata}>
    <Welcome />
    <Testimonials />
    <MyWork />
    <LatestArticles />
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      'url': SITE_URL,
      'name': 'Bianca Fiore',
      'description': author.data.description,
      'author': {
        '@type': 'Person',
        'name': author.data.name,
        'jobTitle': author.data.jobTitle,
        'url': SITE_URL,
      },
    })} />
</BaseLayout>
