---
import { SITE_URL } from "astro:env/client";
import { PAGES_ROUTES } from "@const/index";
import type { SeoMetadata } from "@const/types";
import { getArticle, getTagGroups } from "@infrastructure/cms/content";
import ArticleCard from "@modules/core/components/articleCard/ArticleCard.astro";
import BaseLayout from "@modules/core/components/baseLayout/BaseLayout.astro";
import Breadcrumbs from "@modules/core/components/breadcrumbs/Breadcrumbs.astro";
import "./_tag.css";

const { slug } = Astro.params;
const groups = await getTagGroups();
const matchedTag = groups.flatMap((group) => group.data.tags).find((entry) => entry.slug === slug);

if (!slug || !matchedTag) {
	return Astro.rewrite("/404");
}

const articles = (await Promise.all(matchedTag.articles.map((reference) => getArticle(reference.id))))
	.filter((article): article is NonNullable<typeof article> => Boolean(article))
	.sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());

const tag = { ...matchedTag, articles };
const metadata: Partial<SeoMetadata> = {
	title: `#${slug}`,
	description: `Articles tagged with #${slug}.`,
};
---
<BaseLayout {...metadata}>
    <Breadcrumbs />
    <h1 class="flex justify-center">#{slug}(&times;{tag.count})</h1>    <section class="common-wrapper">
    <ul class="tag__article__list grid">
      {tag.articles?.map((article) => {
        return (
            <li class="tag__article__item relative">
                <ArticleCard {...article} isLandscape />
            </li>
        )
      })}
    </ul>
</section>
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'ItemList',
      'itemListElement': (tag.articles ?? []).map((article, index) => ({
        '@type': 'ListItem',
        'position': index + 1,
        ...(article && {
          'url': new URL(`${PAGES_ROUTES.ARTICLE}${article.data.slug}`, SITE_URL).href,
        }),
      })),
    })} />
</BaseLayout>
