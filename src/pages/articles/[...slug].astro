---
import { Picture } from "astro:assets";
import { getCollection } from "astro:content";
import { HIDE_CHROME, SITE_URL } from "astro:env/client";
import { PAGES_ROUTES } from "@const/index";
import type { SeoMetadata } from "@const/types";
import ArticleDetails from "@modules/article/components/articleDetails/ArticleDetails.astro";
import ReadingProgress from "@modules/article/components/readingProgress/ReadingProgress.astro";
import RepublishedBanner from "@modules/article/components/republishedBanner/RepublishedBanner.astro";
import TableOfContents from "@modules/article/components/tableOfContents/TableOfContents.astro";
import BaseLayout from "@modules/core/components/baseLayout/BaseLayout.astro";
import Breadcrumbs from "@modules/core/components/breadcrumbs/Breadcrumbs.astro";
import RelatedArticles from "@modules/core/components/relatedArticles/RelatedArticles.astro";
import type { InferGetStaticPropsType } from "astro";
import "./_article.css";

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

export const prerender = true;

export async function getStaticPaths() {
	const articles = await getCollection("articles");

	return articles.map((article) => {
		return {
			params: {
				slug: article.data.slug,
			},
			props: {
				article,
			},
		};
	});
}

const { article } = Astro.props;
const metadata: Partial<SeoMetadata> = {
	title: article.data.title,
	description: article.data.description,
	type: "article",
	publishedTime: new Date(article.data.publishDate).toISOString(),
	modifiedTime: article.data.updatedAt,
	author: article.data.author.name,
	tags: article.data.tags?.map((tag: { name: string }) => tag.name),
	...(article.data.featuredImage && {
		image: `https:${article.data.featuredImage.url}`,
		imageWidth: article.data.featuredImage.details.width,
		imageHeight: article.data.featuredImage.details.height,
	}),
};
const scopes = article.data.tableOfContents.map((_, index) => `--section-${index + 1}`).join(",");
---
<BaseLayout {...metadata}>
  {
      article.data.featuredImage && (
          <section class="article__featured-image-wrapper">
              <Picture
                  src={`https:${article.data.featuredImage.url}`}
                  width={article.data.featuredImage.details.width}
                  height={article.data.featuredImage.details.height}
                  formats={['avif', 'webp']}
                  fallbackFormat="jpeg"
                  widths={[640, 960, 1280, 1920]}
                  sizes="100vw"
                  alt={article.data.title}
                  loading="eager"
                  fetchpriority="high"
                  decoding="async"
                  class="article__featured-image"
                  pictureAttributes={{ style: 'display:block;width:100%' }}
                  transition:name=`featured-image-${article.data.slug}`
              />
          </section>
      )
  }
    <ReadingProgress />
    <div class:list={["article-masthead", { "--has-featured": !!article.data.featuredImage }]}>
      {!HIDE_CHROME && <Breadcrumbs />}
      <ArticleDetails article={article} />
    </div>
    {article.data.isRepublished && (
      <RepublishedBanner originalSource={article.data.originalSource} />
    )}
    <article class="article-wrapper" set:html={article.data.content} style={`--scopes: ${scopes}`}>
      {
          !HIDE_CHROME && article.data.tableOfContents.length > 1 &&
          <TableOfContents tableOfContents={article.data.tableOfContents} />
      }
    </article>
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      'url': Astro.url.href,
      'headline': article.data.title,
      'description': article.data.description,
      'inLanguage': 'en',
      ...(article.data.featuredImage && {
        'image': {
          '@type': 'ImageObject',
          'url': `https:${article.data.featuredImage.url}`,
          'width': article.data.featuredImage.details.width,
          'height': article.data.featuredImage.details.height,
        },
      }),
      'datePublished': new Date(article.data.publishDate).toISOString(),
      'dateModified': article.data.updatedAt,
      'author': {
        '@type': 'Person',
        'name': article.data.author.name,
        'jobTitle': article.data.author.jobTitle,
        'url': new URL(`${PAGES_ROUTES.ABOUT}`, SITE_URL).href,
      },
      'publisher': {
        '@type': 'Person',
        'name': article.data.author.name,
        'url': new URL(SITE_URL).href,
      },
      'mainEntityOfPage': {
        '@type': 'WebPage',
        '@id': Astro.url.href,
      },
    })} />
    <RelatedArticles article={article} />
</BaseLayout>
