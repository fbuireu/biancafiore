---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import SliderShell from "@modules/core/components/sliderShell/SliderShell.astro";
import "./testimonials-slider.css";

interface Props {
	testimonials: CollectionEntry<"testimonials">[];
}

const { testimonials } = Astro.props;
---

<div class="testimonials__carousel">
	<SliderShell class="testimonials__slider" showTrack={false}>
		{
			testimonials.map((testimonial) => (
				<li class="slider__slide testimonials__slide">
					<figure class="testimonial">
						<blockquote class="testimonial__quote">{testimonial.data.quote}</blockquote>
						<figcaption class="testimonial__attribution">
							<Image
								class="testimonial__avatar"
								src={testimonial.data.image.url}
								alt={testimonial.data.author}
								width={testimonial.data.image.details.width}
								height={testimonial.data.image.details.height}
							/>
							<span class="testimonial__identity">
								<span class="testimonial__author">{testimonial.data.author}</span>
								<span class="editorial-meta testimonial__role">{testimonial.data.role}</span>
							</span>
						</figcaption>
					</figure>
				</li>
			))
		}
	</SliderShell>
	<nav class="testimonials__nav" aria-label="Testimonials navigation">
		<button class="slider__btn testimonials__nav__arrow --is-prev" type="button" aria-label="Previous testimonial">
			←
		</button>
		{
			testimonials.map((testimonial, index) => (
				<button
					class:list={["testimonials__nav__dash --is-clickable", { "--is-active": index === 0 }]}
					type="button"
					data-index={index}
					aria-label={`Go to testimonial by ${testimonial.data.author}`}
				/>
			))
		}
		<button class="slider__btn testimonials__nav__arrow --is-next" type="button" aria-label="Next testimonial">
			→
		</button>
	</nav>
</div>

<script>
	document.addEventListener("astro:page-load", () => {
		document.querySelectorAll<HTMLElement>(".testimonials__carousel").forEach((carousel) => {
			const track = carousel.querySelector<HTMLElement>(".slider__track");
			if (!track) return;

			const slides = Array.from(track.querySelectorAll<HTMLElement>(".slider__slide"));
			const dashes = Array.from(carousel.querySelectorAll<HTMLButtonElement>(".testimonials__nav__dash"));

			const distanceToCenter = (slide: HTMLElement): number => {
				const trackRect = track.getBoundingClientRect();
				const slideRect = slide.getBoundingClientRect();

				return Math.abs(slideRect.left + slideRect.width / 2 - (trackRect.left + trackRect.width / 2));
			};

			const getActiveIndex = (): number =>
				slides.reduce(
					(closest, slide, index) => (distanceToCenter(slide) < distanceToCenter(slides[closest]) ? index : closest),
					0,
				);

			const setActiveDash = (activeIndex: number): void => {
				dashes.forEach((dash, index) => dash.classList.toggle("--is-active", index === activeIndex));
			};

			const goTo = (index: number): void => {
				const target = (index + slides.length) % slides.length;

				slides.at(target)?.scrollIntoView({ behavior: "smooth", block: "nearest", inline: "center" });
				setActiveDash(target);
			};

			dashes.forEach((dash, index) => {
				dash.addEventListener("click", () => goTo(index));
			});

			carousel
				.querySelector<HTMLButtonElement>(".testimonials__nav__arrow.--is-prev")
				?.addEventListener("click", () => goTo(getActiveIndex() - 1));
			carousel
				.querySelector<HTMLButtonElement>(".testimonials__nav__arrow.--is-next")
				?.addEventListener("click", () => goTo(getActiveIndex() + 1));

			track.addEventListener("scroll", () => setActiveDash(getActiveIndex()), { passive: true });
		});
	});
</script>
