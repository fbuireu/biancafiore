---
import { Image } from "astro:assets";
import bianca from "@assets/images/jpg/bianca-fiore.jpg";
import { PAGES_ROUTES } from "@const/index";
import "./welcome.css";
---
<section class="hero common-wrapper" transition:name="welcome-section" transition:animate="slide">
    <div class="hero__inner">
        <div class="hero__grid">
            <div class="hero__headline">
                <p class="editorial-eyebrow hero__eyebrow">Writer · Storyteller · Creative strategist</p>
                <h1 class="hero__title">
                    Stories that move<br />people <em class="hero__ampersand">&amp;</em> the planet<br />forward.
                </h1>
            </div>
            <div class="hero__aside">
                <p class="hero__lede">
                    I'm Bianca Fiore. For a decade I've reported on the people building a fairer, greener world — and
                    helped mission‑driven organisations tell those stories well.
                </p>
                <a class="editorial-cta hero__cta" href={PAGES_ROUTES.ARTICLES}>
                    Read the blog <span class="editorial-cta__arrow" aria-hidden="true">→</span>
                </a>
            </div>
        </div>
        <Image src={bianca} alt="Bianca Fiore" class="hero__portrait" loading="eager" fetchpriority="high" />
    </div>
</section>
