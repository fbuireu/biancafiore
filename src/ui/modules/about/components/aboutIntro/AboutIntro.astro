---
import { Image } from "astro:assets";
import bianca from "@assets/images/jpg/bianca-fiore.jpg";
import SocialNetworks from "@modules/core/components/socialNetworks/SocialNetworks.astro";
import "./about-intro.css";
---
<section class="about-intro common-wrapper" transition:name="about-me-section">
    <div class="about-intro__inner">
        <p class="editorial-eyebrow about-intro__eyebrow">About</p>
        <div class="about-intro__grid">
            <h1 class="about-intro__title">
                Hi, I'm <span translate="no">Bianca</span> — I find the human thread in every story.
            </h1>
            <div class="about-intro__aside">
                <Image src={bianca} alt="Bianca Fiore" class="about-intro__portrait" loading="eager" />
                <SocialNetworks />
            </div>
        </div>
    </div>
</section>
