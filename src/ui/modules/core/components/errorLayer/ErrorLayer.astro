---
import type { HTMLAttributes } from "astro/types";

type Props = HTMLAttributes<"section">;

const { class: classNames, ...props } = Astro.props;
---
<section class:list={['error-layer-wrapper common-wrapper flex column-nowrap justify-center align-center', classNames]}
         {...props}>
    <slot />
</section>
<div class="travolta" />