---
interface Props {
	class?: string;
	delay?: number;
	type?: string;
	prevLabel?: string;
	nextLabel?: string;
}

const {
	class: className,
	delay = 10000,
	type = "articles",
	prevLabel = "Previous slide",
	nextLabel = "Next slide",
} = Astro.props;

const arrowPoints =
	"24 12.001 2.914 12.001 8.208 6.706 7.501 5.999 1 12.501 7.5 19.001 8.207 18.294 2.914 13.001 24 13.001 24 12.001";
---

<div class={className} data-slider-type={type} data-slider-delay={delay}>
	<ul class="slider__track" data-slider-track>
		<slot />
	</ul>
	{
		Astro.slots.has("navigation") ? (
			<slot name="navigation" />
		) : (
			<div class="slider__navigation">
				<button
					class="slider__navigation__button --is-left --is-clickable"
					type="button"
					aria-label={prevLabel}
					data-slider-prev
				>
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 25 25" aria-hidden="true">
						<polygon
							points={arrowPoints}
							fill="currentColor"
							stroke="currentColor"
							stroke-width="0.25"
						/>
					</svg>
				</button>
				<button
					class="slider__navigation__button --is-right --is-clickable"
					type="button"
					aria-label={nextLabel}
					data-slider-next
				>
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 25 25" aria-hidden="true">
						<polygon
							points={arrowPoints}
							fill="currentColor"
							stroke="currentColor"
							stroke-width="0.25"
						/>
					</svg>
				</button>
			</div>
		)
	}
</div>
