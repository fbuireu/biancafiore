---
import type { CollectionEntry } from "astro:content";
import { PAGES_ROUTES } from "@const/index";
import BlurImage from "@modules/core/components/blurImage/BlurImage.astro";
import { articleVariantToClass } from "@modules/core/utils/articleVariantToClass";
import clsx from "clsx";
import "./article-card.css";

type Props = CollectionEntry<"articles"> & { isLandscape?: boolean };

const { isLandscape = false, ...article } = Astro.props;

const MAX_TAGS = 4;
const visibleTags = article.data.tags?.slice(0, MAX_TAGS) ?? [];
const remainingTags = (article.data.tags?.length ?? 0) - visibleTags.length;
---
<a class="article-card__link" href={`${PAGES_ROUTES.ARTICLES}/${article.data.slug}`}
   aria-label={article.data.title}>{' '}</a>
<article
    class={clsx(
        'article-card__item',
        articleVariantToClass(article.data.variant),
        { '--is-landscape': isLandscape },
    )}
>
  {article.data.featuredImage && (
      <div class="article-card__media">
          <BlurImage
              class="article-card__featured-image"
              src={`https:${article.data.featuredImage.url}`}
              width={article.data.featuredImage.details.width}
              height={article.data.featuredImage.details.height}
              alt={article.data.title}
              placeholder={article.data.featuredImage.placeholder}
              transitionName={`featured-image-${article.data.slug}`}
          />
      </div>
  )}
    <time class="article-card__publish-date editorial-meta --is-gold" datetime={article.data.publishDate}>
      {article.data.publishDate}
    </time>
    <h3 class="article-card__title">
      {article.data.title} <span class="article-card__arrow" aria-hidden="true">→</span>
    </h3>
    <p class="article-card__byline editorial-meta">
        by <a href={`${PAGES_ROUTES.TAGS}/${article.data.author.slug}`}
              class="article-card__author --is-clickable --underline-on-hover">{article.data.author.name}</a>
        · {article.data.readingTime} min
    </p>
    <div class="article-card__switch">
        <p class="article-card__excerpt">{article.data.description}</p>
        <div class="article-card__topics">
            <p class="article-card__kicker">In this story</p>
            <ul class="article-card__tags__list">
              {visibleTags.map(({ slug, name }) => (
                  <li class="article-card__tag__item">
                      <a class="--is-clickable --underline-on-hover" href={`${PAGES_ROUTES.TAGS}/${slug}`}>{name}</a>
                  </li>
              ))}
              {remainingTags > 0 && (
                  <li class="article-card__tag__item article-card__tags__overflow">+{remainingTags}</li>
              )}
            </ul>
        </div>
    </div>
</article>
