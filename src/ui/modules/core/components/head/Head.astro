---
import { GOOGLE_ANALYTICS_ID, GOOGLE_TAG_MANAGER_ID } from "astro:env/client";
import { ClientRouter } from "astro:transitions";
import type { SeoMetadata } from "@const/types";
import Seo from "@modules/core/components/seo/Seo.astro";
import "@styles/index.css";
import { Font } from "astro:assets";

type Props = Partial<SeoMetadata>;

const props = Astro.props;
---
<head>
    <meta charset="utf-8" />
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <script is:inline async src=`https://www.googletagmanager.com/gtag/js?id=${GOOGLE_ANALYTICS_ID}`></script>
    <script is:inline async src=`https://www.googletagmanager.com/gtm.js?id=${GOOGLE_TAG_MANAGER_ID}`></script>
    <script is:inline define:vars={{ GOOGLE_ANALYTICS_ID }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}

      const analyticsConsentStatus = (() => {
        try {
          const match = document.cookie.match(/(^| )cc_cookie=([^;]+)/);
          if (match) {
            const data = JSON.parse(decodeURIComponent(match[2]));
            if (Array.isArray(data.categories) && data.categories.includes('analytics')) return 'granted';
          }
        } catch {}
        return 'denied';
      })();

      gtag('consent', 'default', { analytics_storage: analyticsConsentStatus });
      gtag('js', new Date());
      gtag('config', GOOGLE_ANALYTICS_ID);
    </script>
    <Font cssVariable="--font-serif" preload />
    <Font cssVariable="--font-display" preload />
    <Font cssVariable="--font-sans-serif" />
    <ClientRouter />
    <Seo {...props} />
    <slot name="head" />
</head>
