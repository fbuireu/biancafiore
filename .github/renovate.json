{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    "customManagers:biomeVersions",
    ":enableVulnerabilityAlerts"
  ],
  "labels": [
    "dependencies",
    "renovate",
    "bot"
  ],
  "schedule": [
    "on the 1st and 15th day of the month"
  ],
  "minimumReleaseAge": "4 days",
  "rangeStrategy": "pin",
  "pinDigests": true,
  "automergeStrategy": "squash",
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "addLabels": [
      "lock-maintenance"
    ],
    "schedule": [
      "on the 1st and 15th day of the month"
    ]
  },
  "assigneesFromCodeOwners": true,
  "reviewersFromCodeOwners": true,
  "vulnerabilityAlerts": {
    "schedule": [
      "at any time"
    ],
    "labels": [
      "security",
      "vulnerability"
    ]
  },
  "osvVulnerabilityAlerts": true,
  "packageRules": [
    {
      "matchUpdateTypes": [
        "pin",
        "pinDigest",
        "digest"
      ],
      "automerge": true,
      "automergeType": "pr",
      "addLabels": [
        "pin-update"
      ]
    },
    {
      "matchUpdateTypes": [
        "patch"
      ],
      "automerge": true,
      "automergeType": "pr",
      "addLabels": [
        "patch-update"
      ]
    },
    {
      "matchUpdateTypes": [
        "minor"
      ],
      "automerge": true,
      "automergeType": "pr",
      "addLabels": [
        "minor-update"
      ]
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "addLabels": [
        "major-update"
      ],
      "automerge": false
    }
  ]
}
